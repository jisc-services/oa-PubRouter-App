											<mml:mo>&#x2212;</mml:mo>
											<mml:msub>
												<mml:mtext>BAF</mml:mtext>
												<mml:mrow>
													<mml:mi>e</mml:mi>
													<mml:mi>x</mml:mi>
													<mml:mi>p</mml:mi>
												</mml:mrow>
											</mml:msub>
										</mml:mrow>
										<mml:mo>)</mml:mo>
									</mml:mrow>
								</mml:mrow>
							</mml:mfrac>
							<mml:mo>,</mml:mo>
							<mml:mtext>&#x2009;where&#x2009;</mml:mtext>
							<mml:msub>
